graph LR
    Player((Гравець))
    Host((Організатор))

    subgraph "Система E-Kahoot"
        UC01(Створити вікторину)
        UC02(Керувати ігровою кімнатою)
        UC03(Приєднатися за кодом)
        UC04(Відповісти на питання)
        UC05(Переглянути таблицю лідерів)
        UC06(Автентифікація)
    end

    Host --> UC01
    Host --> UC02
    Player --> UC03
    Player --> UC04
    Player --> UC05

    UC01 -.->|include| UC06
    UC02 -.->|include| UC06
    UC03 -.->|include| UC06
    UC04 -.->|extend| UC05
